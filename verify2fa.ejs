<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Verify 2FA - Secure Login System</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="card">
    <h1>🔑 Enter Authentication Code</h1>
    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>
    <form action="/verify-2fa" method="POST">
      <label>6-digit code from your authenticator app</label>
      <input type="text" name="token" required maxlength="6" pattern="\d{6}" autofocus>
      <button type="submit">Verify</button>
    </form>
  </div>
</body>
</html>
