<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Dashboard - Secure Login System</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="card dashboard">
    <div class="badge">✅ Authenticated Session</div>
    <h1>Welcome, <%= username %>!</h1>
    <p>You have successfully logged into the Secure Login System.<br>Your session is protected and will expire after 30 minutes of inactivity.</p>
    <form action="/logout" method="POST">
      <button type="submit">Log Out</button>
    </form>
  </div>
</body>
</html>
